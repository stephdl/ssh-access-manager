# PostgreSQL
POSTGRES_DB=ssh_manager
POSTGRES_USER=ssh_manager
POSTGRES_PASSWORD=changeme

# Nginx
NGINX_PORT=8080

# TLS (optional) — set both to enable HTTPS; paths are container paths
# Mount certificate files into the container (example: ./certs:/data/certs:ro)
# A self-signed certificate is auto-generated only when files are missing at these paths
# NGINX_TLS_CERT_PATH=/data/certs/server.crt
# NGINX_TLS_KEY_PATH=/data/certs/server.key

# Flask
FLASK_SECRET_KEY=changeme

# Email smarthost
SMTP_HOST=mail.example.com
SMTP_PORT=587
SMTP_USERNAME=alerts@example.com
SMTP_PASSWORD=changeme
SMTP_FROM=ssh-manager@example.com
SMTP_ENCRYPTION=starttls
SMTP_TLSVERIFY=1
SMTP_ENABLED=1

# Initial admin password (defaults: username=admin, email=admin@example.com)
ADMIN_PASSWORD=admin
